# ================================================================
# VARIABLES DE ENTORNO - CONFIGURACION DE SEGURIDAD
# ================================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env.production (para producción)
# 2. Rellena TODAS las variables con valores reales
# 3. NUNCA subas .env.production a Git
# 4. Genera API keys seguras de al menos 32 caracteres
#
# ================================================================

# ================================================================
# SUPABASE - BASE DE DATOS Y AUTENTICACION
# ================================================================

# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública de Supabase (anon key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key_aqui

# Clave de servicio de Supabase (MANTENER SECRETA)
SUPABASE_SERVICE_ROLE_KEY=tu_supabase_service_role_key_aqui

# ================================================================
# API KEYS - PROTECCION DE ENDPOINTS
# ================================================================

# API Key para endpoints de importación (/api/import/*)
# Genera una key segura con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# O usa: https://www.uuidgenerator.net/
INTERNAL_API_KEY=tu_api_key_de_minimo_32_caracteres_muy_segura_aqui

# URL base para llamadas internas server-to-server (ej: gps-batch-queue
# crea móviles faltantes invocando /api/import/moviles). Tiene que apuntar
# al propio host de la app. En dev: http://localhost:3000 (o el PORT que uses).
# En prod: la URL publica del servicio (ej: https://track.tu-dominio.com).
APP_BASE_URL=http://localhost:3000

# ================================================================
# CORS - LISTA BLANCA DE ORIGENES
# ================================================================

# URL principal de tu aplicación
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# Orígenes adicionales permitidos (GeneXus, apps móviles, etc.)
ALLOWED_ORIGIN_1=https://app.tu-dominio.com
ALLOWED_ORIGIN_2=https://genexus.tu-empresa.com
ALLOWED_ORIGIN_3=https://api.tu-empresa.com

# ================================================================
# API EXTERNA - BACKEND GENEXUS
# ================================================================

# URL base de la API externa (GeneXus)
API_BASE_URL=https://tu-backend.com/api

# Validación de certificados SSL
# En producción SIEMPRE debe ser "1"
# Solo usar "0" en desarrollo con certificados auto-firmados
NODE_TLS_REJECT_UNAUTHORIZED=1

# ================================================================
# NEXT.JS - CONFIGURACION
# ================================================================

# Entorno de ejecución
NODE_ENV=production

# Puerto en el que corre la aplicación
PORT=3002

# Hostname
HOSTNAME=0.0.0.0

# ================================================================
# MONITOREO Y LOGGING (OPCIONAL)
# ================================================================

# Sentry DSN para monitoreo de errores (opcional)
# SENTRY_DSN=https://tu-sentry-dsn@sentry.io/proyecto

# Logger central (lib/logger.ts)
# Nivel mínimo de logs: error | warn | info | debug
# Default: info en producción, debug en desarrollo
LOG_LEVEL=info

# Modo verbose: imprime headers y bodies completos (proxy, requests).
# Útil para debugging puntual. NUNCA dejarlo en 1 en producción
# permanente porque persiste tokens y datos personales en PM2 logs.
# 1 = on, 0 = off
LOG_VERBOSE=0

# ================================================================
# CONFIGURACION ADICIONAL
# ================================================================

# Tamaño del threadpool de libuv (para conexiones DB)
UV_THREADPOOL_SIZE=4

# Kill switch del rate limiting (auth/login, APIs, proxy, etc).
# Setear en "true" desactiva TODOS los rate limits definidos en lib/rate-limit.ts.
# Util si te autobloqueaste por login fails. Aplicar con: pm2 restart track --update-env
# DISABLE_RATE_LIMIT=true

# ================================================================
# NOTIFICACIONES DE INCIDENCIAS (OPCIONAL)
# ================================================================

# URL del webhook al que se notifica cuando se crea una nueva incidencia.
# Si no está configurado, la incidencia se crea igual (skip silencioso).
# Recomendado: usar un webhook de n8n para desacoplar el canal de notificación.
#   Ejemplo: https://n8n.tu-dominio.com/webhook/incident-created
# Ver docs/WEBHOOK_INCIDENTS.md para instrucciones de configuración en n8n.
# INCIDENT_WEBHOOK_URL=https://n8n.tu-dominio.com/webhook/incident-created

# ================================================================
# DASHBOARD DE METRICAS DE CUMPLIMIENTO (/dashboard/metricas-cumplimiento)
# ================================================================

# Allowlist server-side por email para GET /api/metricas/dashboard.
# CSV de emails (case-insensitive) de los usuarios internos autorizados a ver el
# dashboard de métricas (expone nombres de chofer cruzando empresa). El email se
# valida contra la sesión de Supabase (no spoofeable), a diferencia del scope por
# headers x-track-*. OBLIGATORIO setearla en prod antes de exponer el dashboard;
# sin ella, el endpoint depende solo del gate por headers (spoofeable). Ver la
# sección de seguridad en docs/METRICAS_CUMPLIMIENTO.md.
# METRICAS_DASHBOARD_ALLOWED_EMAILS=admin@riogas.com.uy,otro.admin@riogas.com.uy

# ================================================================
# FEATURE FLAGS
# ================================================================

# Lee móviles desde moviles_dia (read model) en vez de all-positions/moviles-extended
NEXT_PUBLIC_USE_MOVILES_DIA=false

# ================================================================
# MODO DE DESARROLLO (NO USAR EN PRODUCCION)
# ================================================================

# Solo descomentar en desarrollo local
# NODE_ENV=development
# NODE_TLS_REJECT_UNAUTHORIZED=0
